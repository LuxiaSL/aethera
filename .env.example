# Database configuration
DATABASE_URL=sqlite:///blog.sqlite

# Comment tripcode salt - change this to a unique value for production
LUXIBLOG_TRIPCODE_SALT=change-this-to-a-random-string-in-production

# ============================================================================
# IRC fragment generation (local banking loop)
# Auto-loaded by:  uv run python -m aethera.irc.generate
# Real exported env vars override anything set here.
# ============================================================================

# --- Generation: DeepSeek-V3 base on the GPU node vLLM (base/completion model) ---
IRC_GENERATION_PROVIDER=local
IRC_LOCAL_BASE_URL=http://localhost:8000/v1
IRC_LOCAL_MODEL=deepseek-v3-base
# vLLM needs no key — leave blank.
# IRC_LOCAL_API_KEY=

# --- Judge: instruct model via OpenRouter (outbound from laptop) ---
IRC_JUDGE_PROVIDER=openrouter
IRC_JUDGE_MODEL=moonshotai/kimi-k2.5
OPENROUTER_API_KEY=
# Backend routing — OpenRouter spreads a model across backends of very different
# throughput. Default routes to the fastest; pin specific ones once you've
# checked their TPS on the OpenRouter model page.
# IRC_OPENROUTER_PROVIDER_SORT=throughput
# IRC_OPENROUTER_PROVIDERS=moonshotai,fireworks
# IRC_OPENROUTER_ALLOW_FALLBACKS=true

# --- Loop tuning (optional; defaults shown) ---
# IRC_CANDIDATES_PER_BATCH=10
# IRC_AUTOLOOM_THRESHOLD=0.4
# IRC_TOKENS_PER_CANDIDATE=100

# --- Generation sampling (tuned for DeepSeek-V3 base; >0.75 degenerates) ---
# IRC_CANDIDATE_TEMPERATURE=0.7
# IRC_REPETITION_PENALTY=1.05
# IRC_FREQUENCY_PENALTY=0.0
# IRC_PRESENCE_PENALTY=0.0